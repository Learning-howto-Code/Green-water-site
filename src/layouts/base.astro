---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Greenwater's AI-powered greywater reclamation system diverts shower and sink water to your garden — saving up to 50% of indoor water use with no full replumbing required.",
  canonical,
  ogImage = "https://waterwz.com/images/greenwater-og-image.jpg",
  ogType = "website",
  noindex = false,
} = Astro.props;

const siteUrl = "https://waterwz.com";
const baseUrl = import.meta.env.BASE_URL;
const pageTitle = title
  ? `${title} | Greenwater`
  : "Greenwater | Home Greywater Recycling System – Save 25,000 Gallons/Year";
const canonicalUrl = canonical || `${siteUrl}${Astro.url.pathname}`;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#1a2e1a" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Greenwater" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />

    <slot name="head" />
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>

    <nav class="site-nav" id="site-nav">
      <a class="site-brand" href={baseUrl}>
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
          <circle cx="14" cy="14" r="12" stroke="currentColor" stroke-width="2"/>
          <path d="M14 6 C10 12, 10 18, 14 22 C18 18, 18 12, 14 6Z" fill="#5a7247" opacity="0.6"/>
        </svg>
        Greenwater
      </a>
      <div class="nav-links">
        <a href="/#how">How It Works</a>
        <a href="/#faq">FAQ</a>
        <a href={`${baseUrl}contact/`} class="nav-cta">Request Install</a>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <span>© 2026 Greenwater</span>
      <div class="footer-links">
        <a href="#">Privacy</a>
        <a href="#">Terms</a>
        <a href={`${baseUrl}contact/`}>Contact</a>
      </div>
    </footer>

    <script>
      const nav = document.getElementById('site-nav');
      window.addEventListener('scroll', () => {
        nav?.classList.toggle('scrolled', window.scrollY > 50);
      }, { passive: true });
    </script>
  </body>
</html>
