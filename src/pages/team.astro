---
import Baselayout from '../layouts/base.astro';
---

<Baselayout title="Team" noindex={true}>
	<section class="status-wrap">
		<p class="eyebrow">Team</p>
		<h1>In Progress</h1>
		<p>This page is currently being built.</p>
	</section>

	<style>
		.status-wrap {
			max-width: 760px;
			margin: 6rem auto 1.2rem;
			padding: clamp(1rem, 3vw, 1.8rem);
			border-radius: 1rem;
			background: color-mix(in srgb, var(--gw-cream) 82%, white);
			border: 1px solid color-mix(in srgb, var(--gw-olive) 24%, transparent);
			box-shadow: 0 10px 24px rgba(40, 54, 24, 0.12);
		}

		.eyebrow {
			margin: 0;
			font-size: 0.78rem;
			letter-spacing: 0.12em;
			text-transform: uppercase;
			color: var(--gw-rust);
			font-weight: 700;
		}

		h1 {
			font-family: 'DM Serif Display', serif;
			margin: 0.45rem 0 0.5rem;
			color: var(--gw-forest);
			font-size: clamp(1.7rem, 4vw, 2.2rem);
		}

		p {
			margin: 0;
			color: color-mix(in srgb, var(--gw-forest) 84%, black);
		}
	</style>
</Baselayout>
