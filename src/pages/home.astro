---
import Baselayout from '../layouts/base.astro';

const baseUrl = import.meta.env.BASE_URL;
---
<Baselayout title="Home">
	<section class="hero">
		<div class="hero-copy">
			<!-- <p class="eyebrow">Built for homeowners</p> -->
			<h1>Water reclamation systems that cut your water use by up to 50%</h1>
			<p class="lead">
				Greenwater is an all-in-one greywater reclamation device with the least intrusive
				installation on the market, giving you peace of mind that your garden is getting the
				water it needs, guilt-free.
			</p>
			<div class="hero-actions">
				<a class="btn btn-primary btn-lg" href={`${baseUrl}contact/`}>Request Pilot Install</a>
				<a class="btn btn-outline-dark btn-lg" href={`${baseUrl}demo`}>See The Hardware</a>
			</div>
			<ul class="hero-metrics">
				<li>
					<strong>50%</strong>
					<span>Reduction in indoor water use</span>
				</li>
				<li>
					<strong>25,000</strong>
					<span>gallons saved annually</span>
				</li>
				<li>
					<strong>3-stage</strong>
					<span>AI-powered filtration system</span>
				</li>
			</ul>
		</div>
	</section>

	<section class="proof">
		<article>
			<h3>Smart diversion, not full replumbing</h3>
			<p>
				Our valve pack reads source quality and diverts only reclaimable greywater.
				Blackwater lines remain untouched, reducing permitting friction.
			</p>
		</article>
		<article>
			<h3>State-of-the-art AI</h3>
			<p>
				Best-in-class sensors and AI models ensure maximum water savings and peace of mind.
			</p>
		</article>
		<article>
			<h3>One-of-a-kind insights</h3>
			<p>
				Water use, quality, and savings data allow homeowners to understand and take control
				of their water use.
			</p>
		</article>
	</section>

	<section class="faq" aria-label="Frequently asked questions">
		<p class="eyebrow">Q&A</p>
		<h2>Common Questions</h2>

		<details class="faq-item">
			<summary>Can I trust it?</summary>
			<p>
				Greenwater is engineered with safety as the first concern. The water goes through multiple
				filtration systems and is purified from microbial contaminants. Every system is built with
				redundancies and tested far past what it will experience.
			</p>
		</details>

		<details class="faq-item">
			<summary>How much maintenance does it need?</summary>
			<p>
				Every part of the system is engineered for tens of thousands of duty cycles and
				doesn't need any maintenance, ever.
			</p>
		</details>

		<details class="faq-item">
			<summary>Is the water safe for garden and landscape use?</summary>
			<p>
				Yes. Greywater has been proven safe for gardens, with no adverse effects found
				compared to tap water.
			</p>
		</details>
	</section>

	<section class="cta-band">
		<div>
			<p class="eyebrow">Questions? Please reach out.</p>
			<h2>Deploy Greenwater in your home</h2>
		</div>
		<a class="btn btn-dark btn-lg" href={`${baseUrl}contact/`}>Talk To The Team</a>
	</section>

	<style>
		.hero {
			display: block;
			margin-bottom: 2rem;
		}

		.hero-copy {
			background:
				radial-gradient(circle at 10% 0%, color-mix(in srgb, var(--gw-sand) 28%, transparent), transparent 55%),
				radial-gradient(circle at 100% 80%, color-mix(in srgb, var(--gw-olive) 30%, transparent), transparent 45%),
				var(--gw-cream);
			border: 2px solid color-mix(in srgb, var(--gw-forest) 20%, transparent);
			border-radius: 1.25rem;
			padding: clamp(1.25rem, 4vw, 2.5rem);
			box-shadow: 0 18px 36px rgba(40, 54, 24, 0.14);
		}

		.eyebrow {
			margin: 0;
			font-size: 0.78rem;
			letter-spacing: 0.11em;
			text-transform: uppercase;
			color: var(--gw-rust);
			font-weight: 700;
		}

		h1 {
			margin-top: 0.65rem;
			margin-bottom: 0.8rem;
			font-size: clamp(2rem, 5vw, 3.2rem);
			line-height: 1.08;
			color: var(--gw-forest);
			max-width: 20ch;
		}

		.lead {
			margin: 0;
			max-width: 58ch;
			font-size: clamp(1rem, 2.1vw, 1.15rem);
			color: color-mix(in srgb, var(--gw-forest) 85%, black);
		}

		.hero-actions {
			display: flex;
			flex-wrap: wrap;
			gap: 0.75rem;
			margin-top: 1.35rem;
		}

		.hero-metrics {
			margin: 1.6rem 0 0;
			padding: 0;
			list-style: none;
			display: grid;
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: 0.75rem;
		}

		.hero-metrics li {
			background: color-mix(in srgb, var(--gw-cream) 65%, white);
			border: 1px solid color-mix(in srgb, var(--gw-sand) 45%, transparent);
			border-radius: 0.85rem;
			padding: 0.75rem;
			display: flex;
			flex-direction: column;
			gap: 0.2rem;
		}

		.hero-metrics strong {
			color: var(--gw-rust);
			font-size: 1.15rem;
			line-height: 1;
		}

		.hero-metrics span {
			font-size: 0.86rem;
			color: var(--gw-forest);
		}

		.proof {
			display: grid;
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: 1rem;
			margin-bottom: 2rem;
		}

		.proof article {
			background: color-mix(in srgb, var(--gw-cream) 78%, white);
			border: 1px solid color-mix(in srgb, var(--gw-olive) 24%, transparent);
			border-radius: 1rem;
			padding: 1.1rem;
			transform: translateY(8px);
			opacity: 0;
			animation: rise 600ms ease forwards;
		}

		.proof article:nth-child(2) {
			animation-delay: 120ms;
		}

		.proof article:nth-child(3) {
			animation-delay: 240ms;
		}

		.proof h3 {
			margin: 0;
			font-size: 1.08rem;
			color: var(--gw-forest);
		}

		.proof p {
			margin: 0.5rem 0 0;
			color: color-mix(in srgb, var(--gw-forest) 84%, black);
		}

		.faq {
			margin-bottom: 2rem;
			padding: 1.25rem;
			border-radius: 1rem;
			background: color-mix(in srgb, var(--gw-cream) 80%, white);
			border: 1px solid color-mix(in srgb, var(--gw-olive) 24%, transparent);
			box-shadow: 0 12px 24px rgba(40, 54, 24, 0.1);
		}

		.faq h2 {
			margin: 0.4rem 0 1rem;
			font-size: clamp(1.3rem, 2.2vw, 1.8rem);
			color: var(--gw-forest);
		}

		.faq-item {
			border: 1px solid color-mix(in srgb, var(--gw-sand) 36%, transparent);
			background: color-mix(in srgb, var(--gw-cream) 92%, white);
			border-radius: 0.7rem;
			padding: 0.7rem 0.85rem;
		}

		.faq-item + .faq-item {
			margin-top: 0.7rem;
		}

		.faq-item summary {
			cursor: pointer;
			font-weight: 700;
			color: var(--gw-forest);
		}

		.faq-item p {
			margin: 0.55rem 0 0;
			color: color-mix(in srgb, var(--gw-forest) 84%, black);
		}

		.cta-band {
			background: linear-gradient(110deg, var(--gw-forest), var(--gw-olive));
			color: #ffffff;
			border-radius: 1.1rem;
			padding: 1.1rem 1.2rem;
			display: flex;
			gap: 1rem;
			justify-content: space-between;
			align-items: center;
			box-shadow: 0 10px 25px rgba(40, 54, 24, 0.26);
		}

		.cta-band h2 {
			margin: 0.4rem 0 0;
			font-size: clamp(1.25rem, 2.2vw, 1.75rem);
			max-width: 26ch;
		}

		.cta-band .eyebrow {
			color: var(--gw-rust);
			font-size: 0.95rem;
			letter-spacing: 0.03em;
			text-transform: none;
		}

		@keyframes rise {
			to {
				transform: translateY(0);
				opacity: 1;
			}
		}

		@media (max-width: 980px) {
			.proof {
				grid-template-columns: 1fr;
			}

			.hero-metrics {
				grid-template-columns: 1fr;
			}

			.cta-band {
				flex-direction: column;
				align-items: flex-start;
			}
		}
	</style>
</Baselayout>