---
import Baselayout from '../layouts/base.astro';

const baseUrl = import.meta.env.BASE_URL;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Greenwater",
  "url": "https://waterwz.com",
  "logo": "https://waterwz.com/favicon.svg",
  "description": "AI-powered greywater reclamation systems that divert shower and sink water to your garden, saving up to 25,000 gallons per year.",
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "url": "https://waterwz.com/contact/"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Can I trust a greywater recycling system?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Greenwater is engineered with safety as the first concern. Water passes through multiple filtration systems and is purified from microbial contaminants. Every system is built with redundancies and tested far beyond normal operating conditions."
      }
    },
    {
      "@type": "Question",
      "name": "How much maintenance does a greywater system need?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Every component is engineered for tens of thousands of duty cycles. The system doesn't need any maintenance — ever."
      }
    },
    {
      "@type": "Question",
      "name": "Is recycled greywater safe for garden use?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Greywater has been proven safe for gardens, with no adverse effects compared to tap water. Our filtration exceeds regulatory requirements."
      }
    },
    {
      "@type": "Question",
      "name": "How long does greywater system installation take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A typical install takes less than a day. We connect to existing drain lines without modifying your plumbing stack — no permits required in most jurisdictions."
      }
    }
  ]
};
---
<Baselayout
  title="Home Greywater Recycling System – Save 25,000 Gallons/Year"
  description="Greenwater's AI-powered greywater reclamation system diverts shower and sink water to your garden — saving up to 50% of indoor water use with no full replumbing required."
  canonical="https://waterwz.com/"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

	<!-- HERO -->
	<section class="hero">
		<div class="hero-circles" aria-hidden="true">
			<div class="circle circle-1"></div>
			<div class="circle circle-2"></div>
		</div>
		<div class="hero-content">
			<p class="eyebrow">Home greywater reclamation</p>
			<h1>Cut your water use in half.</h1>
			<p class="lead">
				Greenwater diverts shower and sink water back to your garden —
				no full replumbing, no maintenance, no guilt. Just 25,000 gallons saved every year.
			</p>
			<div class="hero-actions">
				<a class="btn-primary" href={`${baseUrl}contact/`}>Request Pilot Install</a>
				<a class="btn-outline" href={`${baseUrl}demo/`}>See The Hardware →</a>
			</div>
		</div>
	</section>

	<!-- HOW IT WORKS -->
	<section id="how" class="how-section">
		<p class="eyebrow">How it works</p>
		<h2>Smart diversion,<br/>not full replumbing.</h2>
		<div class="steps">
			<div class="step">
				<span class="step-num">01</span>
				<h3>Intelligent Diversion</h3>
				<p>Our valve pack reads source quality in real-time and diverts only reclaimable greywater. Blackwater lines stay untouched — reducing permitting friction to near zero.</p>
			</div>
			<div class="step">
				<span class="step-num">02</span>
				<h3>3-Stage Filtration</h3>
				<p>Sensor-driven AI models continuously optimize a three-stage filtration process, ensuring every drop meets quality thresholds before reaching your garden.</p>
			</div>
			<div class="step">
				<span class="step-num">03</span>
				<h3>Live Insights</h3>
				<p>Water use, quality, and savings data at your fingertips. Understand exactly where your water goes and how much you're saving, updated in real-time.</p>
			</div>
		</div>
	</section>

	<!-- FAQ -->
	<section id="faq" class="faq-section">
		<p class="eyebrow">FAQ</p>
		<h2>Common questions</h2>
		<div class="faq-list">
			<div class="faq-item">
				<button class="faq-btn" aria-expanded="false">
					Can I trust it?
					<span class="faq-icon" aria-hidden="true">+</span>
				</button>
				<div class="faq-body">
					<p>Greenwater is engineered with safety as the first concern. Water passes through multiple filtration systems and is purified from microbial contaminants. Every system is built with redundancies and tested far beyond normal operating conditions.</p>
				</div>
			</div>
			<div class="faq-item">
				<button class="faq-btn" aria-expanded="false">
					How much maintenance does it need?
					<span class="faq-icon" aria-hidden="true">+</span>
				</button>
				<div class="faq-body">
					<p>Every component is engineered for tens of thousands of duty cycles. The system doesn't need any maintenance — ever.</p>
				</div>
			</div>
			<div class="faq-item">
				<button class="faq-btn" aria-expanded="false">
					Is the water safe for garden use?
					<span class="faq-icon" aria-hidden="true">+</span>
				</button>
				<div class="faq-body">
					<p>Yes. Greywater has been proven safe for gardens, with no adverse effects compared to tap water. Our filtration exceeds regulatory requirements.</p>
				</div>
			</div>
			<div class="faq-item">
				<button class="faq-btn" aria-expanded="false">
					How long does installation take?
					<span class="faq-icon" aria-hidden="true">+</span>
				</button>
				<div class="faq-body">
					<p>A typical install takes less than a day. We connect to existing drain lines without modifying your plumbing stack — no permits required in most jurisdictions.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="cta-section">
		<div class="cta-bg" aria-hidden="true"></div>
		<div class="cta-content">
			<h2>Deploy Greenwater in your home</h2>
			<p>Join our pilot program — limited spots available.</p>
			<a href={`${baseUrl}contact/`} class="btn-accent">Talk To The Team</a>
		</div>
	</section>

	<style>
		.eyebrow {
			font-size: 0.8rem;
			letter-spacing: 0.15em;
			text-transform: uppercase;
			color: var(--gw-rust);
			font-weight: 700;
			margin: 0 0 1.5rem;
		}

		/* HERO */
		.hero {
			min-height: 100vh;
			display: flex;
			flex-direction: column;
			justify-content: center;
			padding: 8rem 2.5rem 4rem;
			position: relative;
		}

		.hero-circles {
			position: absolute;
			inset: 0;
			overflow: hidden;
			pointer-events: none;
		}

		.circle {
			position: absolute;
			border-radius: 50%;
		}

		.circle-1 {
			top: 10%;
			right: -8%;
			width: 50vw;
			height: 50vw;
			border: 1px solid rgba(90, 114, 71, 0.12);
			animation: float1 8s ease-in-out infinite;
		}

		.circle-2 {
			top: 18%;
			right: -2%;
			width: 35vw;
			height: 35vw;
			background: rgba(90, 114, 71, 0.04);
			animation: float2 10s ease-in-out infinite;
		}

		@keyframes float1 {
			0%, 100% { transform: translate(0, 0); }
			50% { transform: translate(-12px, 18px); }
		}

		@keyframes float2 {
			0%, 100% { transform: translate(0, 0); }
			50% { transform: translate(8px, -14px); }
		}

		.hero-content {
			max-width: 1200px;
			margin: 0 auto;
			width: 100%;
			position: relative;
		}

		.hero-content h1 {
			font-family: 'DM Serif Display', serif;
			font-size: clamp(2.5rem, 6vw, 6.6rem);
			line-height: 1.05;
			color: var(--gw-forest);
			max-width: 16ch;
			margin: 0 0 2rem;
		}

		.lead {
			font-size: 1.2rem;
			line-height: 1.65;
			color: var(--gw-text-muted);
			max-width: 48ch;
			margin: 0 0 2.5rem;
		}

		.hero-actions {
			display: flex;
			gap: 1rem;
			flex-wrap: wrap;
		}

		.btn-primary {
			text-decoration: none;
			background: var(--gw-rust);
			color: #fff;
			padding: 1rem 2rem;
			border-radius: 100px;
			font-size: 1rem;
			font-weight: 600;
			display: inline-block;
			transition: transform 0.25s, box-shadow 0.25s;
		}

		.btn-primary:hover {
			transform: translateY(-2px);
			box-shadow: 0 8px 24px rgba(196, 96, 58, 0.3);
			color: #fff;
		}

		.btn-outline {
			text-decoration: none;
			color: var(--gw-forest);
			padding: 1rem 2rem;
			border-radius: 100px;
			font-size: 1rem;
			font-weight: 600;
			border: 1.5px solid var(--gw-forest);
			display: inline-block;
			transition: background 0.25s, color 0.25s;
		}

		.btn-outline:hover {
			background: var(--gw-forest);
			color: #fff;
		}

		/* HOW IT WORKS */
		.how-section {
			max-width: 1200px;
			margin: 0 auto 8rem;
			padding: 0 2.5rem;
		}

		.how-section h2 {
			font-family: 'DM Serif Display', serif;
			font-size: clamp(2rem, 3.5vw, 3rem);
			line-height: 1.1;
			color: var(--gw-forest);
			max-width: 20ch;
			margin: 0 0 4rem;
		}

		.steps {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 2rem;
		}

		.step {
			padding: 2rem 0;
			border-top: 2px solid var(--gw-forest);
		}

		.step-num {
			font-family: 'DM Serif Display', serif;
			font-size: 3rem;
			color: rgba(26, 46, 26, 0.08);
			line-height: 1;
			display: block;
			margin-bottom: 1rem;
		}

		.step h3 {
			font-size: 1.15rem;
			font-weight: 700;
			margin: 0 0 0.75rem;
			color: var(--gw-forest);
		}

		.step p {
			font-size: 0.95rem;
			line-height: 1.7;
			color: var(--gw-text-muted);
			margin: 0;
		}

		/* FAQ */
		.faq-section {
			max-width: 720px;
			margin: 0 auto 8rem;
			padding: 0 2.5rem;
		}

		.faq-section h2 {
			font-family: 'DM Serif Display', serif;
			font-size: clamp(1.8rem, 3vw, 2.5rem);
			line-height: 1.1;
			color: var(--gw-forest);
			margin: 0 0 3rem;
		}

		.faq-item {
			border-bottom: 1px solid rgba(26, 46, 26, 0.1);
		}

		.faq-btn {
			background: none;
			border: none;
			cursor: pointer;
			width: 100%;
			display: flex;
			justify-content: space-between;
			align-items: center;
			font-family: 'DM Sans', sans-serif;
			font-size: 1.1rem;
			font-weight: 600;
			color: var(--gw-forest);
			text-align: left;
			padding: 1.5rem 0;
		}

		.faq-icon {
			transition: transform 0.3s ease;
			font-size: 1.4rem;
			font-weight: 300;
			color: var(--gw-rust);
			flex-shrink: 0;
			margin-left: 1rem;
			line-height: 1;
			display: inline-block;
		}

		.faq-item.open .faq-icon {
			transform: rotate(45deg);
		}

		.faq-body {
			max-height: 0;
			overflow: hidden;
			transition: max-height 0.4s ease, opacity 0.3s ease;
			opacity: 0;
		}

		.faq-item.open .faq-body {
			max-height: 300px;
			opacity: 1;
		}

		.faq-body p {
			padding-bottom: 1.5rem;
			font-size: 0.95rem;
			line-height: 1.7;
			color: var(--gw-text-muted);
			margin: 0;
		}

		/* CTA */
		.cta-section {
			margin: 0 2.5rem 4rem;
			padding: clamp(3rem, 6vw, 5rem);
			background: var(--gw-forest);
			border-radius: 1.5rem;
			position: relative;
			overflow: hidden;
			text-align: center;
		}

		.cta-bg {
			position: absolute;
			inset: 0;
			background:
				radial-gradient(circle at 30% 50%, rgba(90, 114, 71, 0.3), transparent 60%),
				radial-gradient(circle at 80% 20%, rgba(196, 96, 58, 0.15), transparent 50%);
			pointer-events: none;
		}

		.cta-content {
			position: relative;
		}

		.cta-content h2 {
			font-family: 'DM Serif Display', serif;
			font-size: clamp(2rem, 4vw, 3.2rem);
			line-height: 1.1;
			color: #fff;
			max-width: 18ch;
			margin: 0 auto 1rem;
		}

		.cta-content p {
			color: rgba(255, 255, 255, 0.6);
			font-size: 1.1rem;
			margin: 0 0 2rem;
		}

		.btn-accent {
			text-decoration: none;
			background: var(--gw-rust);
			color: #fff;
			padding: 1rem 2.5rem;
			border-radius: 100px;
			font-size: 1rem;
			font-weight: 600;
			display: inline-block;
			transition: transform 0.25s, box-shadow 0.25s;
		}

		.btn-accent:hover {
			transform: translateY(-2px);
			box-shadow: 0 8px 24px rgba(196, 96, 58, 0.3);
			color: #fff;
		}

		@media (max-width: 768px) {
			.hero {
				padding: 7rem 1.25rem 3rem;
			}

			.steps {
				grid-template-columns: 1fr;
			}

			.how-section,
			.faq-section {
				padding: 0 1.25rem;
			}

			.cta-section {
				margin: 0 1rem 3rem;
			}
		}
	</style>

	<script>
		document.querySelectorAll('.faq-btn').forEach(btn => {
			btn.addEventListener('click', () => {
				const item = btn.closest('.faq-item');
				const isOpen = item?.classList.contains('open');
				document.querySelectorAll('.faq-item').forEach(el => el.classList.remove('open'));
				document.querySelectorAll('.faq-btn').forEach(b => b.setAttribute('aria-expanded', 'false'));
				if (!isOpen && item) {
					item.classList.add('open');
					btn.setAttribute('aria-expanded', 'true');
				}
			});
		});
	</script>
</Baselayout>
